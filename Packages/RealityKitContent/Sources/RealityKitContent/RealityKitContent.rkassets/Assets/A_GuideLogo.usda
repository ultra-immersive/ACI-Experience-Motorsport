    def RealityKitMeshSortingGroup "Model_Sorting_Group" (
        active = true
    )
    {
        token depthPass = "None"
    }

    def "A_LogoAci" (
        references = @A_LogoAci.usda@
    )
    {
        float3 xformOp:scale = (1, 1, 1)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        over "guideLogoAci"
        {
            over "textAci"
            {
                over "B__zierCircle_012"
                {
                    def RealityKitComponent "MeshSorting"
                    {
                        rel group = </Root/Model_Sorting_Group>
                        token info:id = "RealityKit.MeshSorting"
                        int priorityInGroup = 3
                    }
                }
            }

            over "circleAci"
            {
                over "Plane_013"
                {
                    def RealityKitComponent "MeshSorting"
                    {
                        rel group = </Root/Model_Sorting_Group>
                        token info:id = "RealityKit.MeshSorting"
                        int priorityInGroup = 2
                    }
                }
            }

            over "ringAci"
            {
                over "HierarchicalFade"
                {
                    float opacity = 0
                }
            }

            over "sphereAci"
            {
                over "Cube_001"
                {
                    def RealityKitComponent "MeshSorting"
                    {
                        rel group = </Root/Model_Sorting_Group>
                        token info:id = "RealityKit.MeshSorting"
                        int priorityInGroup = 4
                    }
                }
            }
        }

        over "HierarchicalFade"
        {
            float opacity = 1
        }

        over "Materials"
        {
            over "M_GuideCircle"
            {
                float inputs:Animation = 0
            }

            over "M_GuideText"
            {
                float inputs:Animation = 0
            }
        }

        def RealityKitComponent "ImageBasedLightReceiver"
        {
            rel iblEntity = </Root/HDRI>
            uniform token info:id = "RealityKit.ImageBasedLightReceiver"
        }
    }

    def Xform "HDRI" (
        active = true
    )
    {
        def RealityKitComponent "ImageBasedLight"
        {
            token blendMode = "single"
            bool enableBlend = 0
            asset ibl = @../Textures/HDRI/fakeInteriorGuide.hdr@
            uniform token info:id = "RealityKit.ImageBasedLight"
            float intensityExponent = 1
            bool isGlobalIBL = 0
        }
    }
}

