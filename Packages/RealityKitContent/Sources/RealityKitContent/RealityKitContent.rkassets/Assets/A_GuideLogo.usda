                    float birthRate = 50
                    float colorEvolutionPower = 1
                    float4 endColorA = (0.44624832, 0.60156727, 0.9822504, 1)
                    float noiseStrength = 0.1
                    token opacityOverLife = "EaseFadeIn"
                    float particleSize = 0.005
                    float particleSizeVariation = 0.0025
                    float3 radialGravityCenter = (0, 0, 0)
                    float radialGravityStrength = 0
                    float sizeMultiplierAtEndOfLifespan = 0
                    float4 startColorA = (0.5372549, 0.96862745, 0.99215686, 1)
                    bool useEndColor = 1
                    bool useEndColorRange = 0
                    bool useStartColorRange = 0
                }

                def RealityKitStruct "spawnedEmitter"
                {
                }
            }
        }
    }

