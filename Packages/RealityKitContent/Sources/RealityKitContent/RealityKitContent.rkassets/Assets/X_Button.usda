            float inputs:clearcoat = 1
            float3 inputs:clearcoatNormal
            float inputs:clearcoatRoughness = 0.1
            color3f inputs:emissiveColor.connect = </Root/X_Glass/Add_1.outputs:out>
            float inputs:metallic = 0
            float inputs:opacity.connect = </Root/X_Glass/Separate3.outputs:outb>
            float inputs:roughness = 0.3
            float inputs:specular = 1
            float2 ui:nodegraph:node:pos = (577.96533, -138.84961)
            int ui:nodegraph:node:stackingOrder = 673
        }

        over "UnlitSurface" (
            active = false
        )
        {
