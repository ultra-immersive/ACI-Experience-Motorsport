            float outputs:out
            float2 ui:nodegraph:node:pos = (-989.74927, 261.5389)
            int ui:nodegraph:node:stackingOrder = 19436
        }

        def Shader "separate2"
        {
            uniform token info:id = "ND_separate2_vector2"
            float2 inputs:in.connect = </Root/Circuit/texcoord.outputs:out>
            float outputs:outx
            float outputs:outy
            float2 ui:nodegraph:node:pos = (-835.24365, 452.68347)
            float2 ui:nodegraph:node:size = (113.5, 117)
            int ui:nodegraph:node:stackingOrder = 19436
        }

        def Shader "Image"
        {
            uniform token info:id = "ND_image_color3"
            color3f inputs:default
            asset inputs:file (
                colorSpace = "lin_displayp3"
            )
            asset inputs:file.connect = </Root/Circuit.inputs:HighlightColor>
            string inputs:filtertype
            float2 inputs:texcoord.connect = </Root/Circuit/combine2.outputs:out>
            string inputs:uaddressmode
            string inputs:vaddressmode
            color3f outputs:out
            float2 ui:nodegraph:node:pos = (-8.416992, 426.8212)
            int ui:nodegraph:node:stackingOrder = 19436
        }

        def Shader "Time" (
