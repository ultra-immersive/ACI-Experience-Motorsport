        )
        {
            uniform token info:id = "ND_remap_float"
            float inputs:in.connect = </Root/Circuit/Time.outputs:out>
            float inputs:inhigh
            float inputs:inlow = 0
            float inputs:outhigh = 1.05
            delete float inputs:outlow.connect = </Root/Materials/MM_CircuitGlass_Trail.inputs:Opacity>
            float outputs:out
            float2 ui:nodegraph:node:pos = (-1088.4233, 149.39594)
            int ui:nodegraph:node:stackingOrder = 19436
        }

        def Shader "oneminus"
        {
            uniform token info:id = "ND_realitykit_oneminus_float"
            float inputs:in.connect = </Root/Circuit/separate2.outputs:outx>
            float outputs:out
            float2 ui:nodegraph:node:pos = (-685.751, 375.16647)
            float2 ui:nodegraph:node:size = (112.5, 99)
            int ui:nodegraph:node:stackingOrder = 19436
        }

        def Shader "Screen"
        {
            uniform token info:id = "ND_screen_color3"
            color3f inputs:bg.connect = </Root/Circuit/Multiply.outputs:out>
            color3f inputs:fg.connect = </Root/Circuit/Mix.outputs:out>
            float inputs:mix
            color3f outputs:out
            float2 ui:nodegraph:node:pos = (570.45966, 161.36623)
            int ui:nodegraph:node:stackingOrder = 19493
        }

        def Shader "Multiply"
        {
            uniform token info:id = "ND_multiply_color3"
            color3f inputs:in1.connect = </Root/Circuit/Image.outputs:out>
            color3f inputs:in2.connect = </Root/Circuit.inputs:ConstantColor3_1>
            color3f outputs:out
            float2 ui:nodegraph:node:pos = (338.12866, 327.91037)
            int ui:nodegraph:node:stackingOrder = 19438
        }

        def Shader "Mix_1"
        {
            uniform token info:id = "ND_mix_color3"
            color3f inputs:bg.connect = </Root/Circuit/Screen.outputs:out>
            color3f inputs:fg.connect = </Root/Circuit.inputs:ConstantColor3_1>
            float inputs:mix = 1
