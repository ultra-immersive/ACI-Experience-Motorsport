        }

        def Shader "Separate2_1"
        {
            uniform token info:id = "ND_separate2_vector2"
            float2 inputs:in.connect = </Root/M_BillboardDiorama.inputs:Fix_Border_Mask>
            float outputs:outx
            float outputs:outy
            float2 ui:nodegraph:node:pos = (-1175.6523, 204.78516)
            int ui:nodegraph:node:stackingOrder = 451
        }
    }

    def "MI_Billboard" (
        active = true
        instanceable = true
        references = </Root/M_BillboardDiorama>
    )
    {
        asset inputs:Mask = @../Textures/BillboardsDiorama/T_Billboard_A.jpg@
    }

    def Scope "SFX" (
        active = true
    )
    {
        reorder nameChildren = ["Source", "AudioFiles"]
        def Xform "Source" (
            active = true
        )
        {
            quatf xformOp:orient = (1, 0, 0, 0)
            float3 xformOp:scale = (1, 1, 1)
            float3 xformOp:translate = (0, 0.3, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

            def RealityKitComponent "AudioLibrary"
            {
                uniform token info:id = "RealityKit.AudioLibrary"

                def RealityKitDict "resources"
                {
                    string[] keys = ["PanelAppearing.wav"]
                    rel values = </Root/SFX/AudioFiles/PanelAppearing_wav>
                }
            }

            def RealityKitComponent "SpatialAudio"
            {
                uniform token info:id = "RealityKit.SpatialAudio"
                float rolloffFactor = 0
            }
        }

        def Scope "AudioFiles" (
            active = true
        )
        {
            def RealityKitAudioFile "PanelAppearing_wav"
            {
                uniform asset file = @../Audio/AudioFiles/PanelAppearing.wav@
                uniform bool shouldLoop = 0
            }
        }
    }
}

