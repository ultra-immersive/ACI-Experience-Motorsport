        asset inputs:MetallicMap = @../../Textures/LanciaStratos/B-Transparent_Metallic.png@
        asset inputs:NormalMap = @../../Textures/LanciaStratos/B-Transparent_Normal.png@
        asset inputs:OpacityMap = @../../Textures/LanciaStratos/B-Transparent_Alpha.png@
        asset inputs:RoughnessMap = @../../Textures/LanciaStratos/B-Transparent_Roughness.png@
    }

    def "MI_TRA_C_BackWheels" (
        active = true
        instanceable = true
        references = </Root/MM_TransitionPBR>
    )
    {
        asset inputs:AOMap = @../../Textures/LanciaStratos/C-Wheels_AO.png@
        asset inputs:BaseColorMap = @../../Textures/LanciaStratos/C-Wheels_BaseColor.png@
        asset inputs:MetallicMap = @../../Textures/LanciaStratos/C-Wheels_Metallic.png@
        asset inputs:NormalMap = @../../Textures/LanciaStratos/C-Wheels_Normal.png@
        asset inputs:RoughnessMap = @../../Textures/LanciaStratos/C-Wheels_Roughness.png@
