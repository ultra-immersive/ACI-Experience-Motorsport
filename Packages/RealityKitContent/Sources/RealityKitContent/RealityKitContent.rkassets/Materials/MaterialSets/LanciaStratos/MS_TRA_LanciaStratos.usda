#usda 1.0
(
    customLayerData = {
        string creator = "Reality Composer Pro Version 2.0 (494.8.1)"
    }
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Root"
{
    reorder nameChildren = ["M_LanciaStratos", "MM_TransitionPBR", "MI_TRA_A_CarBodyFront", "MI_TRA_A_CarBodyBack", "MI_TRA_B_BlackLightsGlass", "MI_TRA_C_BackWheels", "MI_TRA_D_SeatBelt", "MI_TRA_E_AcessoriesFuel", "MI_TRA_Z_CarBottom"]
    def "MM_TransitionPBR" (
        active = true
        references = @../../MasterMaterials.usda@</Root/MM_TransitionPBR>
    )
    {
        float inputs:TransitionAmount = 0
        float inputs:TransitionLocationHigh = 1.1
        float inputs:TransitionSpan = 0.5
        color3f inputs:WireframeColor = (0.9411765, 0.99607843, 1) (
            colorSpace = "srgb_displayp3"
        )
    }

    def "MI_TRA_A_CarBodyFront" (
        active = true
        instanceable = true
        references = </Root/MM_TransitionPBR>
    )
    {
        asset inputs:AOMap = @../../Textures/LanciaStratos/A-CarBodyFront_AO.png@
        asset inputs:BaseColorMap = @../../Textures/LanciaStratos/A-CarBodyFront_BaseColor.png@
        asset inputs:MetallicMap = @../../Textures/LanciaStratos/A-CarBodyFront_Metallic.png@
        asset inputs:NormalMap = @../../Textures/LanciaStratos/A-CarBodyFront_Normal.png@
        asset inputs:RoughnessMap = @../../Textures/LanciaStratos/A-CarBodyFront_Roughness.png@
    }

    def "MI_TRA_A_CarBodyBack" (
        active = true
        instanceable = true
        references = </Root/MM_TransitionPBR>
    )
    {
        asset inputs:AOMap = @../../Textures/LanciaStratos/A-CarBodyBack_AO.png@
        asset inputs:BaseColorMap = @../../Textures/LanciaStratos/A-CarBodyBack_BaseColor.png@
        asset inputs:MetallicMap = @../../Textures/LanciaStratos/A-CarBodyBack_Metallic.png@
        asset inputs:NormalMap = @../../Textures/LanciaStratos/A-CarBodyBack_Normal.png@
        asset inputs:RoughnessMap = @../../Textures/LanciaStratos/A-CarBodyBack_Roughness.png@
    }

