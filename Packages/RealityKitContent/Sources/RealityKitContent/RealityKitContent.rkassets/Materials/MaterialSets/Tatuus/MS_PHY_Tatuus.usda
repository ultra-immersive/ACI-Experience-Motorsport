            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname.connect = </Root/MI_PHY_Transparent.inputs:frame:stPrimvarName>
                float2 outputs:result
            }
        }

        def Shader "normal"
        {
            uniform token info:id = "UsdUVTexture"
            asset inputs:file = @../../Textures/Tatuus/E-Transparent_Normal.png@
            float2 inputs:st.connect = </Root/MI_PHY_Transparent/normal/TexCoordReader.outputs:result>
            normal3f outputs:rgb

            def Shader "TexCoordReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname.connect = </Root/MI_PHY_Transparent.inputs:frame:stPrimvarName>
                float2 outputs:result
            }
        }

        def Shader "roughness"
