#usda 1.0
(
    customLayerData = {
        string creator = "Reality Composer Pro Version 2.0 (494.8.1)"
    }
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Root"
{
    reorder nameChildren = ["MI_PHY_Transparent", "MI_PHY_Covers", "MI_PHY_MediumSized", "MI_PHY_SmallParts", "MI_PHY_CarBody01", "MI_PHY_CarBody02", "MaterialSwatch", "TestMaterial"]
    def Material "MI_PHY_Transparent"
    {
        token cullMode = "back" (
            allowedTokens = ["unspecified", "none", "front", "back"]
        )
        token inputs:frame:stPrimvarName = "st" (
            customData = {
                dictionary realitykit = {
                    bool hide = 1
                }
            }
        )
        token outputs:mtlx:surface
        token outputs:realitykit:vertex
        token outputs:surface.connect = </Root/MI_PHY_Transparent/UsdPreviewSurface.outputs:surface>

        def Shader "UsdPreviewSurface"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.18, 0.18, 0.18)
            color3f inputs:diffuseColor.connect = </Root/MI_PHY_Transparent/diffuseColor.outputs:rgb>
            float inputs:metallic = 0
            float inputs:metallic.connect = </Root/MI_PHY_Transparent/metallic.outputs:r>
            normal3f inputs:normal = (0, 0, 1)
            normal3f inputs:normal.connect = </Root/MI_PHY_Transparent/normal.outputs:rgb>
            float inputs:occlusion = 1
            float inputs:occlusion.connect = </Root/MI_PHY_Transparent/occlusion.outputs:r>
            float inputs:opacity = 1
            float inputs:opacity.connect = </Root/MI_PHY_Transparent/opacity.outputs:r>
            float inputs:roughness = 0.5
            float inputs:roughness.connect = </Root/MI_PHY_Transparent/roughness.outputs:r>
            token outputs:surface
        }

        def Shader "diffuseColor"
        {
            uniform token info:id = "UsdUVTexture"
            asset inputs:file = @../../Textures/Tatuus/E-Transparent_BaseColor.png@
            float2 inputs:st.connect = </Root/MI_PHY_Transparent/diffuseColor/TexCoordReader.outputs:result>
            color3f outputs:rgb

            def Shader "TexCoordReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname.connect = </Root/MI_PHY_Transparent.inputs:frame:stPrimvarName>
                float2 outputs:result
            }
        }

        def Shader "opacity"
        {
            uniform token info:id = "UsdUVTexture"
            asset inputs:file = @../../Textures/Tatuus/E-Transparent_Alpha.png@
            float2 inputs:st.connect = </Root/MI_PHY_Transparent/opacity/TexCoordReader.outputs:result>
            float outputs:r

            def Shader "TexCoordReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname.connect = </Root/MI_PHY_Transparent.inputs:frame:stPrimvarName>
                float2 outputs:result
            }
        }

        def Shader "metallic"
        {
            uniform token info:id = "UsdUVTexture"
