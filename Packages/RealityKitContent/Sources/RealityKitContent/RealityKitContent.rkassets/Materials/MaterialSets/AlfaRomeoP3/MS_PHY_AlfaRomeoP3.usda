#usda 1.0
(
    customLayerData = {
        string creator = "Reality Composer Pro Version 2.0 (494.8.1)"
    }
    defaultPrim = "Root"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Root"
{
    reorder nameChildren = ["A_CarBody", "B_NonMetal", "C_Transparent", "D_Metal", "E_Screws", "Z_Cover", "MaterialSwatch"]
    def Xform "MaterialSwatch" (
        active = true
    )
    {
        reorder nameChildren = ["Swatch_MI_PHY_CarBody", "Swatch_MI_PHY_NonMetal", "Swatch_MI_PHY_Transparent", "Swatch_MI_PHY_Metal", "Swatch_MI_PHY_Screws", "Swatch_MI_PHY_Cover"]
        float2 ui:nodegraph:node:pos = (20, 20)
        int ui:nodegraph:node:stackingOrder = 1
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        def "Swatch_MI_PHY_CarBody" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
            references = @../../../Geometry/SwatchMesh.usdc@
        )
        {
            rel material:binding = </Root/A_CarBody> (
                bindMaterialAs = "weakerThanDescendants"
            )
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
        }

        def "Swatch_MI_PHY_NonMetal" (
            active = true
            prepend apiSchemas = ["MaterialBindingAPI"]
